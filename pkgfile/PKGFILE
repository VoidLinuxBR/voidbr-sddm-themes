pkgname=voidbr-sddm-themes
pkgdesc="Sddm Themes for VoidBR"
pkgver=$(date +%Y%m%d)
pkgrel=$(date +%H%M)
arch=('any')
license=('MIT')
url="https://github.com/voidlinuxbr/${pkgname}"
source=("git+${url}.git")
md5sums=('SKIP')
depends=(
	sddm
	qt6ct
	qt5-svg
	qt5-graphicaleffects
	qt5-quickcontrols
	qt5-quickcontrols2
	qt5-wayland
	qt6-wayland
)
backup=/etc/sddm.conf

package() {
	local dirs=("usr" "etc" "opt")
	#  echo "DESTDIR=$DESTDIR"
	#  echo "srcdir=$srcdir"
	#  echo "_pkgsrc=$_pkgsrc"

	for dir in "${dirs[@]}"; do
		if [ -d "${_pkgsrc}/${dir}" ]; then
			cp -a "${_pkgsrc}/${dir}" "$DESTDIR/"
		fi
	done
}

pre_install() {
	log "Iniciando instalação"
}

post_install() {
	log "Finalizando instalação"
}

pre_upgrade() {
	log "Iniciando upgrade"
}

post_upgrade() {
	log "Finalizando upgrade"
}
